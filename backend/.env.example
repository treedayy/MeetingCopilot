# Optional — without a key the app runs in offline heuristic mode with the demo meeting.
ANTHROPIC_API_KEY=
# Model used for live analysis and report generation.
ANTHROPIC_MODEL=claude-sonnet-4-6
# SQLite by default; point at Postgres for production, e.g. postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./meetingcopilot.db
# Optional Deepgram key for server-side streaming STT (browser Web Speech API works without it).
DEEPGRAM_API_KEY=
# How many new transcript segments trigger an analysis pass.
ANALYSIS_EVERY_SEGMENTS=4
