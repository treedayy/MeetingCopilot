# --- Model router (Layer 5) -------------------------------------------------
# All optional. With nothing set, the deterministic pipeline runs the whole
# product offline. Provider: auto | anthropic | openai | none
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
# Any /chat/completions-compatible endpoint: OpenAI, Azure, vLLM, Ollama…
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Per-tier model overrides (defaults resolved per provider):
#   small  — classification/tagging     medium — live enrichment/verification
#   large  — post-meeting reports
MODEL_SMALL=
MODEL_MEDIUM=
MODEL_LARGE=

# --- Storage -----------------------------------------------------------------
# SQLite by default; point at Postgres for production, e.g. postgresql+psycopg://user:pass@host/db
DATABASE_URL=sqlite:///./meetingcopilot.db

# --- Speech ------------------------------------------------------------------
# Reserved for server-side streaming STT (browser Web Speech API works without it).
DEEPGRAM_API_KEY=

# --- Pipeline ----------------------------------------------------------------
ANALYSIS_EVERY_SEGMENTS=4
